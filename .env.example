# Example environment configuration for pvgb2026
# Copy to .env.local and fill in actual values

PAYLOAD_SECRET=your-secret-here

# IMPORTANT: Use Postgres/Neon for R2-Uploads (NOT SQLite!)
# SQLite + R2 together does not work - S3Storage Plugin requires a real database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require
USE_SQLITE=false

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=your-bucket-name

NEXT_PUBLIC_EXACTDN_DOMAIN=your-domain.com

# Additional settings
PAYLOAD_SKIP_PUSH=true
PREVIEW_SECRET=your-preview-secret
CRON_SECRET=your-cron-secret
REVALIDATE_SECRET=your-revalidate-secret
PINY_VISUAL_SELECT=true
