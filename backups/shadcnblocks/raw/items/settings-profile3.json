{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "settings-profile3",
  "title": "Settings-profile",
  "description": "A multi-card profile settings layout with cover image upload, avatar, basic info, and regional preferences.",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "utils",
    "avatar",
    "button",
    "card",
    "input",
    "label",
    "select",
    "textarea",
    "https://www.diceui.com/r/file-upload.json"
  ],
  "files": [
    {
      "path": "block/settings-profile3.tsx",
      "content": "\"use client\";\n\nimport { Upload, X } from \"lucide-react\";\nimport { useState } from \"react\";\n\nimport { FileUpload, FileUploadTrigger } from \"@/components/diceui/file-upload\";\nimport { Avatar, AvatarFallback, AvatarImage } from \"@/components/ui/avatar\";\nimport { Button } from \"@/components/ui/button\";\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardHeader,\n  CardTitle,\n} from \"@/components/ui/card\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/components/ui/select\";\nimport { Textarea } from \"@/components/ui/textarea\";\nimport { cn } from \"@/lib/utils\";\n\ninterface ProfileFormData {\n  name: string;\n  email: string;\n  avatar?: string;\n  coverImage?: string;\n  bio?: string;\n  timezone?: string;\n  language?: string;\n}\n\ninterface SettingsProfile3Props {\n  defaultValues?: Partial<ProfileFormData>;\n  onSave?: (data: ProfileFormData) => void;\n  className?: string;\n}\n\nconst SettingsProfile3 = ({\n  defaultValues = {\n    name: \"Sam Rivera\",\n    email: \"sam.rivera@email.com\",\n    avatar:\n      \"https://deifkwefumgah.cloudfront.net/shadcnblocks/block/avatar/avatar5.jpg\",\n    coverImage:\n      \"https://deifkwefumgah.cloudfront.net/shadcnblocks/block/photos/pawel-czerwinski-O4fAgtXLRwI-unsplash.jpg\",\n    bio: \"Creative director and brand strategist helping startups tell their stories. Coffee enthusiast and amateur photographer.\",\n    timezone: \"America/Los_Angeles\",\n    language: \"en\",\n  },\n  className,\n}: SettingsProfile3Props) => {\n  const [avatarFiles, setAvatarFiles] = useState<File[]>([]);\n  const [coverFiles, setCoverFiles] = useState<File[]>([]);\n\n  const initials = defaultValues.name\n    ?.split(\" \")\n    .map((n) => n[0])\n    .join(\"\")\n    .toUpperCase();\n\n  const avatarPreview =\n    avatarFiles.length > 0\n      ? URL.createObjectURL(avatarFiles[0])\n      : defaultValues.avatar;\n\n  const coverPreview =\n    coverFiles.length > 0\n      ? URL.createObjectURL(coverFiles[0])\n      : defaultValues.coverImage;\n\n  return (\n    <div className={cn(\"w-full max-w-2xl space-y-6\", className)}>\n      {/* Cover Image Card */}\n      <Card className=\"overflow-hidden pt-0\">\n        <FileUpload\n          value={coverFiles}\n          onValueChange={setCoverFiles}\n          accept=\"image/*\"\n          maxFiles={1}\n          maxSize={5 * 1024 * 1024}\n        >\n          <div\n            className=\"relative h-32 bg-muted bg-cover bg-center sm:h-40\"\n            style={{\n              backgroundImage: coverPreview\n                ? `url(${coverPreview})`\n                : undefined,\n            }}\n          >\n            <div className=\"absolute inset-0 bg-black/20\" />\n            <div className=\"absolute right-3 bottom-3 flex gap-2\">\n              <FileUploadTrigger asChild>\n                <Button size=\"sm\" variant=\"secondary\" className=\"shadow-md\">\n                  <Upload className=\"mr-2 size-4\" />\n                  Change Cover\n                </Button>\n              </FileUploadTrigger>\n              {coverFiles.length > 0 && (\n                <Button\n                  size=\"icon\"\n                  variant=\"secondary\"\n                  className=\"size-8 shadow-md\"\n                  onClick={() => setCoverFiles([])}\n                >\n                  <X className=\"size-4\" />\n                </Button>\n              )}\n            </div>\n          </div>\n        </FileUpload>\n\n        <CardContent className=\"-mt-12 pb-6 sm:-mt-14\">\n          <div className=\"flex flex-col items-center gap-4 sm:flex-row sm:items-end\">\n            <FileUpload\n              value={avatarFiles}\n              onValueChange={setAvatarFiles}\n              accept=\"image/*\"\n              maxFiles={1}\n              maxSize={2 * 1024 * 1024}\n            >\n              <div className=\"relative\">\n                <Avatar className=\"size-24 border-4 border-card shadow-lg sm:size-28\">\n                  <AvatarImage\n                    src={avatarPreview}\n                    alt={defaultValues.name}\n                    className=\"object-cover\"\n                  />\n                  <AvatarFallback className=\"text-2xl font-semibold\">\n                    {initials}\n                  </AvatarFallback>\n                </Avatar>\n                <FileUploadTrigger asChild>\n                  <Button\n                    size=\"icon\"\n                    variant=\"secondary\"\n                    className=\"absolute -right-1 -bottom-1 size-8 rounded-full shadow-md\"\n                  >\n                    <Upload className=\"size-4\" />\n                  </Button>\n                </FileUploadTrigger>\n              </div>\n            </FileUpload>\n            <div className=\"space-y-1 text-center sm:pb-1 sm:text-left\">\n              <h3 className=\"text-lg font-semibold\">{defaultValues.name}</h3>\n              <p className=\"text-sm text-muted-foreground\">\n                {defaultValues.email}\n              </p>\n            </div>\n          </div>\n        </CardContent>\n      </Card>\n\n      {/* Basic Info Card */}\n      <Card>\n        <CardHeader>\n          <CardTitle>Basic Information</CardTitle>\n          <CardDescription>\n            This information will be displayed on your public profile\n          </CardDescription>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          <div className=\"space-y-2\">\n            <Label htmlFor=\"name\">Display Name</Label>\n            <Input id=\"name\" defaultValue={defaultValues.name} />\n          </div>\n          <div className=\"space-y-2\">\n            <Label htmlFor=\"bio\">About</Label>\n            <Textarea\n              id=\"bio\"\n              rows={4}\n              defaultValue={defaultValues.bio}\n              placeholder=\"Tell others about yourself\"\n            />\n            <p className=\"text-xs text-muted-foreground\">\n              You can use markdown for formatting\n            </p>\n          </div>\n        </CardContent>\n      </Card>\n\n      {/* Preferences Card */}\n      <Card>\n        <CardHeader>\n          <CardTitle>Preferences</CardTitle>\n          <CardDescription>\n            Customize your experience with regional settings\n          </CardDescription>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          <div className=\"grid gap-4 sm:grid-cols-2\">\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"language\">Language</Label>\n              <Select defaultValue={defaultValues.language}>\n                <SelectTrigger id=\"language\">\n                  <SelectValue placeholder=\"Select language\" />\n                </SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"en\">English</SelectItem>\n                  <SelectItem value=\"es\">Español</SelectItem>\n                  <SelectItem value=\"fr\">Français</SelectItem>\n                  <SelectItem value=\"de\">Deutsch</SelectItem>\n                  <SelectItem value=\"ja\">日本語</SelectItem>\n                  <SelectItem value=\"zh\">中文</SelectItem>\n                </SelectContent>\n              </Select>\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"timezone\">Timezone</Label>\n              <Select defaultValue={defaultValues.timezone}>\n                <SelectTrigger id=\"timezone\">\n                  <SelectValue placeholder=\"Select timezone\" />\n                </SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"America/New_York\">\n                    Eastern Time (ET)\n                  </SelectItem>\n                  <SelectItem value=\"America/Chicago\">\n                    Central Time (CT)\n                  </SelectItem>\n                  <SelectItem value=\"America/Denver\">\n                    Mountain Time (MT)\n                  </SelectItem>\n                  <SelectItem value=\"America/Los_Angeles\">\n                    Pacific Time (PT)\n                  </SelectItem>\n                  <SelectItem value=\"Europe/London\">\n                    Greenwich Mean Time (GMT)\n                  </SelectItem>\n                  <SelectItem value=\"Europe/Paris\">\n                    Central European Time (CET)\n                  </SelectItem>\n                  <SelectItem value=\"Asia/Tokyo\">\n                    Japan Standard Time (JST)\n                  </SelectItem>\n                </SelectContent>\n              </Select>\n            </div>\n          </div>\n        </CardContent>\n      </Card>\n\n      {/* Actions */}\n      <div className=\"flex justify-end gap-2\">\n        <Button variant=\"outline\">Cancel</Button>\n        <Button>Save Changes</Button>\n      </div>\n    </div>\n  );\n};\n\nexport { SettingsProfile3 };\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}