{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "application-shell9",
  "title": "Application-shell",
  "description": "A code editor-style application shell with activity bar, file explorer sidebar with collapsible folders, and panel toggle for secondary content area.",
  "dependencies": [
    "lucide-react"
  ],
