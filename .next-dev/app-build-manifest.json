{
  "pages": {
    "/global-error": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/global-error.js"
    ],
    "/error": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/error.js"
    ],
    "/(frontend)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(frontend)/layout.css",
      "static/chunks/app/(frontend)/layout.js"
    ],
    "/(frontend)/error": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(frontend)/error.js"
    ],
    "/(frontend)/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(frontend)/loading.js"
    ],
    "/(frontend)/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(frontend)/not-found.js"
    ],
    "/(frontend)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(frontend)/page.css",
      "static/chunks/app/(frontend)/page.js"
    ],
    "/(payload)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(payload)/layout.css",
      "static/chunks/app/(payload)/layout.js"
    ],
    "/(payload)/admin/[[...segments]]/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(payload)/admin/[[...segments]]/not-found.css",
      "static/chunks/app/(payload)/admin/[[...segments]]/not-found.js"
    ],
    "/(payload)/admin/[[...segments]]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(payload)/admin/[[...segments]]/page.css",
      "static/chunks/app/(payload)/admin/[[...segments]]/page.js"
    ],
    "/(payload)/api/[...slug]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(payload)/api/[...slug]/route.css",
      "static/chunks/app/(payload)/api/[...slug]/route.js"
    ],
    "/(frontend)/[slug]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(frontend)/[slug]/page.css",
      "static/chunks/app/(frontend)/[slug]/page.js"
    ]
  }
}